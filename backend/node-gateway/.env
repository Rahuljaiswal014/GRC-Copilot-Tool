# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=grc_copilot
PG_USER=grc_user
PG_PASSWORD=grc_secure_password_2025

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/grc_copilot

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=86400

# ─── FastAPI Analysis Engine ──────────────────────────────
FASTAPI_URL=http://localhost:8000

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Frontend ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
